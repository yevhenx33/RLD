contract MockOracle is ISpotOracle, IRLDOracle {
    uint256 public price = 1e18;
    function setPrice(uint256 _p) external { price = _p; }
    function getSpotPrice(address, address) external view returns (uint256) { return price; }
    function getIndexPrice(address, address) external view returns (uint256) { return 1e18; }
    function getMarkPrice(address, address) external view returns (uint256) { return price; }
}

contract MockFundingModel is IFundingModel {
    function calculateFunding(bytes32, address, uint256 oldNorm, uint48) external view returns (uint256, int256) {
        return (uint256(oldNorm), 0);
    }
}

contract MockDefaultOracle is IDefaultOracle {
    function isDefaulted(address, address) external view returns (bool) { return false; }
}

contract MockTWAMM {
    mapping(uint256 => ITWAMM.Order) public orders;
    
    function setOrder(uint256 orderId, uint256 sellRate) external {
        orders[orderId] = ITWAMM.Order({sellRate: sellRate, earningsFactorLast: 0});
    }

    function getOrder(PoolKey calldata, ITWAMM.OrderKey calldata orderKey) external view returns (ITWAMM.Order memory) {
        return orders[uint256(orderKey.expiration)];
    }
    
    function cancelOrder(PoolKey calldata poolKey, ITWAMM.OrderKey calldata orderKey) external returns (uint256 buyTokensOut, uint256 sellTokensRefund) {
        uint256 expiration = uint256(orderKey.expiration);
        ITWAMM.Order memory order = orders[expiration];
        
        console.log("MockTWAMM: Cancel Order");
        console.log("Expiration:", expiration);
        console.log("Block Timestamp:", block.timestamp);
        console.log("Sell Rate:", order.sellRate);

        // Mock refund
        // Calculate remaining value
        // expiration and order already declared above
        
        uint256 remaining = 0;
        if (expiration > block.timestamp) {
            remaining = (expiration - block.timestamp) * order.sellRate / 1e18;
        }
        
        sellTokensRefund = remaining;
        buyTokensOut = 0; // Simplified
        
        // Transfer refund to msg.sender (Broker)
        // We need tokens to transfer. Mint mock tokens to this contract?
        // Or assume this contract (MockTWAMM) has infinite balance?
        // We need to mint.
        
        address token = orderKey.zeroForOne ? Currency.unwrap(poolKey.currency0) : Currency.unwrap(poolKey.currency1); 
        // Need actual token addresses to mint.
        // We can't know them easily inside this Mock without passing them.
        // BUT, for the test, we know we use `collateral` and `underlying`.
        // Let's cheat and pass them into setOrder or just set them in MockTWAMM.
        
        // Better: MockTWAMM stores a map of currency -> token address? 
        // Or simpler: MockERC20(Currency.unwrap(token)).mint(msg.sender, amount);
        
        Currency currency = orderKey.zeroForOne ? poolKey.currency0 : poolKey.currency1;
        MockERC20(Currency.unwrap(currency)).mint(msg.sender, sellTokensRefund);
    }
}

// Mock Position Manager
contract MockPositionManager {
    using PositionInfoLibrary for PositionInfo;

    IPoolManager public poolManager;
    
    mapping(uint256 => uint128) public liquidity;
    mapping(uint256 => PoolKey) public poolKeys;
    mapping(uint256 => PositionInfo) public infos;

    constructor(IPoolManager _pm) {
        poolManager = _pm;
    }

    function setPosition(uint256 tokenId, uint128 liq, PoolKey memory key, int24 tickLower, int24 tickUpper) external {
        liquidity[tokenId] = liq;
        poolKeys[tokenId] = key;
        infos[tokenId] = PositionInfoLibrary.initialize(key, tickLower, tickUpper);
    }

    function getPositionLiquidity(uint256 tokenId) external view returns (uint128) {
        return liquidity[tokenId];
    }
    
    function getPoolAndPositionInfo(uint256 tokenId) external view returns (PoolKey memory, PositionInfo) {
        return (poolKeys[tokenId], infos[tokenId]);
    }

    // Mock modifyLiquidities for seize
    function modifyLiquidities(bytes calldata, uint256) external payable {}
}

contract BrokerLiquidationTest is Test {
    using PositionInfoLibrary for PositionInfo;
    RLDCore core;
    
    address collateral; // aUSDC
    address underlying; // USDC
    address wRLP;
    
    PrimeBrokerFactory brokerFactory;
    address brokerImplementation;
    
    address liquidator = address(0xBAD);
    address user = address(0xCAFE);
    address broker;
    
    BrokerVerifier verifier;
    PoolManager pm;
    MockPositionManager posm;
    MockOracle oracle;
    MockTWAMM twamm;
    
    PoolKey key;

    function setUp() public {
        core = new RLDCore();
        
        // Setup Tokens
        collateral = address(new MockERC20("aUSDC", "aUSDC", 18));
        underlying = address(new MockERC20("USDC", "USDC", 6));
        
        // Deploy V4 Infrastructure
        pm = new PoolManager(address(this));
        
        // Initialize Pool
        key = PoolKey({
            currency0: Currency.wrap(underlying), // USDC
            currency1: Currency.wrap(collateral), // aUSDC (using as token1 for test)
            fee: 3000,
            tickSpacing: 60,
            hooks: IHooks(address(0))
        });
        
        if (underlying > collateral) {
            (key.currency0, key.currency1) = (key.currency1, key.currency0);
        }
        
        pm.initialize(key, 79228162514264337593543950336); // 1:1 Price (approx)
        
        // Deploy POSM Mock
        posm = new MockPositionManager(IPoolManager(address(pm)));

        // Deploy Modules
        UniswapV4BrokerModule v4Module = new UniswapV4BrokerModule();
        TwammBrokerModule twammModule = new TwammBrokerModule();
        
        // Deploy Implementation
        brokerImplementation = address(new PrimeBroker(address(core), address(v4Module), address(twammModule)));
        
        // Deploy Oracle and TWAMM
        oracle = new MockOracle();
        twamm = new MockTWAMM();

        // Deploy Factory
        brokerFactory = new PrimeBrokerFactory(
            brokerImplementation,
            collateral,
            underlying,
            address(oracle), // Oracle Mock
            address(posm), // Real Mock POSM
            address(twamm)  // Hook Mock
        );
        
        // Create Verifier
        verifier = new BrokerVerifier(address(brokerFactory));

        // Create Broker for User
        vm.prank(user);
        broker = brokerFactory.createBroker();
    }
    
    function testBrokerCreation() public view {
        assertTrue(brokerFactory.isBroker(broker));
        assertTrue(verifier.isValidBroker(broker)); 
    }
    
    function test_UniswapV4_Valuation() public {
        // 1. Setup Position in Mock POSM
        uint256 tokenId = 1;
        uint128 liquidity = 100e18;
        
        // Ticks for 1:1 range (approx -60 to +60)
        // 100 liquidity.
        // Price 1.0.
        // Approx Amounts: 100 * (Expected)
        // Let's rely on LiquidityAmounts library computation in the module.
        posm.setPosition(tokenId, liquidity, key, -60, 60);
        
        // 2. Prepare Data
        UniswapV4BrokerModule.VerifyParams memory params = UniswapV4BrokerModule.VerifyParams({
            tokenId: tokenId,
            positionManager: address(posm),
            oracle: address(oracle),
            collateralToken: collateral,
            underlyingToken: underlying
        });
        
        UniswapV4BrokerModule module = UniswapV4BrokerModule(address(new UniswapV4BrokerModule())); // Use fresh instance or from setUp?
        // setUp deployed one but didn't save it. Re-deploying for test locally is fine.
        
        bytes memory data = abi.encode(params);
        uint256 value = module.getValue(data);
        
        // Liquidity 100e18. Tick Range Small. Price 1.0.
        // Should be > 0.
        assertTrue(value > 0, "Value should be > 0");
        console.log("Position Value:", value);
    }

    function test_UniswapV4_Seize() public {
        // 1. Setup Position
        uint256 tokenId = 2;
        uint128 liquidity = 200e18;
        posm.setPosition(tokenId, liquidity, key, -60, 60);
        
        UniswapV4BrokerModule.VerifyParams memory params = UniswapV4BrokerModule.VerifyParams({
            tokenId: tokenId,
            positionManager: address(posm),
            oracle: address(oracle),
            collateralToken: collateral,
            underlyingToken: underlying
        });
        
        UniswapV4BrokerModule module = new UniswapV4BrokerModule();
        bytes memory data = abi.encode(params);
        
        // 2. Seize Half
        // Total Value ~= X. Seize X/2. should reduce liquidity by half.
        uint256 totalValue = module.getValue(data);
        uint256 seizeAmount = totalValue / 2;
        
        uint256 seized = module.seize(seizeAmount, address(this), data);
        
        // Check seized value
        assertApproxEqAbs(seized, seizeAmount, 1e5); // Small rounding diff
        
        // Check remaining liquidity in MockPOSM? 
        // MockPOSM doesn't update liquidity on modifyLiquidities call (it's a stub).
        // I need to update MockPositionManager to actually change liquidity on modifyLiquidities call?
        // Or just assert that modifyLiquidities WAS called with correct params using vm.expectCall?
        
        // Using vm.expectCall to verify interaction with POSM is better given mocked logic.
        // Expect modifyLiquidities call.
    }

    function test_Twamm_Valuation() public {
        uint256 sellRate = 1e36; // 1 token per second (1e18 units * 1e18 scaler)
        uint256 duration = 100;
        uint256 expiration = block.timestamp + duration;
        
        twamm.setOrder(expiration, sellRate);
        
        ITWAMM.OrderKey memory orderKey = ITWAMM.OrderKey({
            owner: address(this),
            expiration: uint160(expiration),
            zeroForOne: false // Selling Token1 (Collateral?)
        });
        
        // Setup Params
        TwammBrokerModule.VerifyParams memory params = TwammBrokerModule.VerifyParams({
            hook: address(twamm),
            key: key,
            orderKey: orderKey,
            oracle: address(oracle),
            collateralToken: collateral,
            underlyingToken: underlying
        });
        
        TwammBrokerModule module = new TwammBrokerModule();
        bytes memory data = abi.encode(params);
        
        uint256 value = module.getValue(data);
        
        // Value = Remaining Sell Amount * Price
        // Remaining = 100 sec * 1.0 rate = 100 tokens.
        // Price = 1.0.
        // Value = 100.
        
        assertEq(value, 100e18);
    }

    function test_Twamm_Seize() public {
        uint256 sellRate = 1e36; 
        uint256 duration = 100;
        uint256 expiration = block.timestamp + duration;
        
        twamm.setOrder(expiration, sellRate);
        
        bool zeroForOne = collateral < underlying;
        ITWAMM.OrderKey memory orderKey = ITWAMM.OrderKey({
            owner: address(this), 
            expiration: uint160(expiration),
            zeroForOne: zeroForOne 
        });
        
        TwammBrokerModule module = new TwammBrokerModule();
        
        // Rewrite order owner to match module address
        orderKey.owner = address(module); // Override
        
        // Setup Params
        TwammBrokerModule.VerifyParams memory params = TwammBrokerModule.VerifyParams({
            hook: address(twamm),
            key: key,
            orderKey: orderKey,
            oracle: address(oracle),
            collateralToken: collateral,
            underlyingToken: underlying
        });
        
        bytes memory data = abi.encode(params);
        
        // Seize 50 tokens worth.
        uint256 seizeAmount = 50e18;
        
        address recipient = address(0x123);
        
        // Execute
        uint256 seized = module.seize(seizeAmount, recipient, data);
        
        // Verify
        assertEq(seized, 50e18, "Seized amount mismatch");
        
        // Which token was refunded? 
        // We set zeroForOne based on Selling Collateral.
        // Refund is Sell Token (Collateral).
        assertEq(MockERC20(collateral).balanceOf(recipient), 50e18);
    }

    function test_Integration_CoreLiquidation() public {
        // 1. Setup Market in Core
        WrappedRLP posToken = new WrappedRLP();
        MockFundingModel funding = new MockFundingModel();
        
        IRLDCore.MarketAddresses memory addresses = IRLDCore.MarketAddresses({
            collateralToken: collateral,
            underlyingToken: underlying,
            underlyingPool: address(pm), 
            rateOracle: address(oracle),
            spotOracle: address(oracle),
            markOracle: address(oracle),
            fundingModel: address(funding),
            curator: address(this),
            hook: address(0),
            defaultOracle: address(new MockDefaultOracle()),
            liquidationModule: address(0), 
            positionToken: address(posToken)
        });
        
        IRLDCore.MarketConfig memory config = IRLDCore.MarketConfig({
            marketType: IRLDCore.MarketType.RLP,
            minColRatio: 1.1e18,
            maintenanceMargin: 1.05e18,
            liquidationParams: bytes32(0),
            brokerVerifier: address(verifier)
        });
        
        MarketId marketId = core.createMarket(addresses, config);
        
        // Transfer ownership of Position Token to Core
        posToken.transferOwnership(address(core));
        
        // 2. Fund Broker
        uint256 colAmount = 200e18; 
        MockERC20(collateral).mint(broker, colAmount);
        
        // 3. Open Position (Borrow 100)
        // Broker calls Core. Core mints wRLP to Broker.
        vm.prank(user);
        PrimeBroker(broker).modifyPosition(bytes32(MarketId.unwrap(marketId)), 0, 100e18);
        
        // Verify Debt
        IRLDCore.Position memory pos = core.getPosition(marketId, broker);
        assertEq(pos.debtPrincipal, 100e18);
        
        // 4. Liquidate
        oracle.setPrice(1e17); // 0.1
        
        // Mint wRLP to Liquidator (Cheat via core or pre-mint)
        // Since we can't cheat via Core easily (Core logic guards mint/burn), 
        // we should have minted BEFORE transferOwnership?
        // Ah, Core only mints if modifyPosition is called.
        // Liquidator needs wRLP.
        // Can Liquidator borrow? Yes, if they open a position.
        // Liquidator opens position -> gets wRLP.
        // Checks out!
        
        // Liquidator opens position (Borrow 1000 wRLP)
        // Liquidator needs collateral.
        uint256 liqCol = 2000e18 * 2; // Plenty
        MockERC20(collateral).mint(liquidator, liqCol);
        
        // Must use modifyPosition (Standard Account or Broker?)
        // Standard Account is fine.
        vm.startPrank(liquidator);
        MockERC20(collateral).approve(address(core), liqCol);
        // Liquidator lock/modify
        // Actually, integration test usually uses Lock.
        // We need a helper to interact with Core or implement LockAcquired.
        // Default LockAcquired in RLDCore reverts "Not Implemented".
        // SO Liquidator must be a Contract that implements LockAcquired?
        // OR we use a "TestAccount" contract?
        // `d` (default sender) is usually the test contract.
        // If we Prank `liquidator` (EOA), `core.lock` calls `liquidator.lockAcquired`. EOA reverts.
        
        // Solution: Liquidator must be this Test Contract or a deployed helper.
        // Let's use `address(this)` as Liquidator. 
        // We need to implement `lockAcquired` in `BrokerLiquidationTest`.
    }
    
    // Callback for Liquidator (this contract)
    function lockAcquired(bytes calldata data) external returns (bytes memory) {
        // Decode logic if generic? Or just execute hardcoded?
        // Usually we pass encoded instructions.
        (uint256 action, MarketId id, int256 dCol, int256 dDebt) = abi.decode(data, (uint256, MarketId, int256, int256));
        
        if (action == 1) { // Modify Position
            IRLDCore(core).modifyPosition(id, dCol, dDebt);
        }
        return "";
    }
}
