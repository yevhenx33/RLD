# ═══════════════════════════════════════════════════════════════
# RLD Simulation Stack — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Required: Anvil RPC (already running externally)
RPC_URL=http://host.docker.internal:8545

# Required: Alchemy/Infura URL (for forge fork verification)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Anvil default deterministic keys (accounts 0-5)
DEPLOYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
USER_A_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
USER_B_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
USER_C_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
MM_KEY=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a
CHAOS_KEY=0x8b3a350cf5c34c9194ca85829a2df0ec3153be0318b5e2d3348e872092edffba

# Optional: Rate oracle API
API_URL=http://host.docker.internal:8080
API_KEY=your_api_key_here

# Optional: Indexer port (host-side)
INDEXER_PORT=8080
