#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# forge-persist — Persistent Mainnet Forks in One Command
# ═══════════════════════════════════════════════════════════════
#
# Replaces Anvil for long-running forks. Uses Reth (MDBX) for
# disk-backed persistence with zero memory leaks.
#
# Usage:
#   forge-persist --fork-url https://eth-mainnet.g.alchemy.com/v2/KEY
#   forge-persist --fork-url $RPC --deploy "forge script Deploy.s.sol --broadcast"
#   forge-persist --resume
#
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

VERSION="0.1.0"

# ─── Resolve paths ────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"
source "$LIB_DIR/defaults.sh"

# ─── Parse arguments ─────────────────────────────────────────
FORK_URL=""
FORK_BLOCK=""
DEPLOY_CMD=""
CHAIN_ID=31337
PORT=8545
BLOCK_TIME=1
DATA_DIR=".forge-persist"
RESUME=false
FRESH=false
BACKGROUND=false
FUND_ARGS=()
FUND_KEYS=()

show_help() {
    cat <<EOF
forge-persist v${VERSION} — Persistent Mainnet Forks

USAGE:
  forge-persist --fork-url <RPC_URL> [OPTIONS]
  forge-persist --resume [OPTIONS]

FORK MODE (first run):
  --fork-url <URL>         Mainnet RPC to fork from (required first time)
  --fork-block <NUM>       Block number to fork at (default: latest)
  --deploy <CMD>           Command to run on temp Anvil before migration
                           e.g. "forge script Deploy.s.sol --broadcast"
  --chain-id <NUM>         Chain ID (default: 31337)

RUN MODE (subsequent):
  --resume                 Boot from saved genesis (skip Anvil)
  --fresh                  Wipe data and re-fork

NODE CONFIG:
  --port <NUM>             RPC port (default: 8545)
  --block-time <SEC>       Block interval in seconds (default: 1)
  --data-dir <PATH>        Storage directory (default: .forge-persist/)
  --background             Run in background

UTILITIES:
  --fund-key <PRIVKEY>     Pre-fund account with 10000 ETH (repeatable)
  --status                 Show node status
  --stop                   Stop background node

EXAMPLES:
  # Simple mainnet fork
  forge-persist --fork-url \$ETH_RPC_URL

  # Fork + deploy + persist
  forge-persist --fork-url \$ETH_RPC_URL \\
    --deploy "forge script script/Deploy.s.sol --broadcast --rpc-url http://localhost:8545"

  # Resume previous session
  forge-persist --resume

  # Fund a dev key with ETH
  forge-persist --fork-url \$ETH_RPC_URL --fund-key 0xac0974bec39a...

EOF
    exit 0
}

show_version() {
    echo "forge-persist v${VERSION}"
    exit 0
}

# Parse args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fork-url)     FORK_URL="$2"; shift 2 ;;
        --fork-block)   FORK_BLOCK="$2"; shift 2 ;;
        --deploy)       DEPLOY_CMD="$2"; shift 2 ;;
        --chain-id)     CHAIN_ID="$2"; shift 2 ;;
        --port)         PORT="$2"; shift 2 ;;
        --block-time)   BLOCK_TIME="$2"; shift 2 ;;
        --data-dir)     DATA_DIR="$2"; shift 2 ;;
        --fund-key)     FUND_KEYS+=("$2"); shift 2 ;;
        --resume)       RESUME=true; shift ;;
        --fresh)        FRESH=true; shift ;;
        --background)   BACKGROUND=true; shift ;;
        --status)       show_status "$DATA_DIR"; exit 0 ;;
        --stop)         stop_node "$DATA_DIR"; exit 0 ;;
        --help|-h)      show_help ;;
        --version|-v)   show_version ;;
        *)              fail "Unknown option: $1 (use --help)"; exit 1 ;;
    esac
done

# ─── Validation ──────────────────────────────────────────────
if [ "$RESUME" = false ] && [ -z "$FORK_URL" ]; then
    # Check if genesis exists for implicit resume
    if [ -f "$DATA_DIR/genesis.json" ]; then
        info "Found existing genesis. Use --resume to boot, or --fresh to re-fork."
        exit 1
    fi
    fail "Missing --fork-url (required for first run)"
    echo "  Usage: forge-persist --fork-url https://eth-mainnet.g.alchemy.com/v2/KEY"
    exit 1
fi

if [ "$RESUME" = true ] && [ ! -f "$DATA_DIR/genesis.json" ]; then
    fail "No saved genesis in $DATA_DIR/ — run with --fork-url first"
    exit 1
fi

# ─── Preflight checks ───────────────────────────────────────
header "PREFLIGHT"

check_tool "cast" "Install Foundry: curl -L https://foundry.paradigm.xyz | bash"
check_tool "anvil" "Install Foundry: curl -L https://foundry.paradigm.xyz | bash"

if ! command -v reth &>/dev/null; then
    step "0" "Reth not found — installing..."
    bash "$LIB_DIR/../install.sh" || { fail "Failed to install reth"; exit 1; }
fi
check_tool "reth" "Install: https://paradigmxyz.github.io/reth/installation"
check_tool "python3" "Install Python 3.8+"
check_tool "jq" "Install: apt install jq / brew install jq"

ok "All tools available"

# ─── Create data dir ─────────────────────────────────────────
mkdir -p "$DATA_DIR"

GENESIS_FILE="$DATA_DIR/genesis.json"
RETH_DATADIR="$DATA_DIR/reth-data"
RETH_LOG="$DATA_DIR/reth.log"
ANVIL_LOG="$DATA_DIR/anvil.log"
PIDFILE="$DATA_DIR/reth.pid"

# ─── Fresh wipe ──────────────────────────────────────────────
if [ "$FRESH" = true ]; then
    step "0" "Wiping data directory..."
    rm -rf "$RETH_DATADIR" "$GENESIS_FILE"
    ok "Clean slate"
    RESUME=false
fi

# ═════════════════════════════════════════════════════════════
# PHASE 1: FORK (skip if --resume)
# ═════════════════════════════════════════════════════════════
if [ "$RESUME" = false ]; then
    header "PHASE 1: FORK MAINNET"

    # 1a. Start Anvil
    step "1a" "Starting temporary Anvil fork..."
    ANVIL_ARGS=(anvil --fork-url "$FORK_URL" --port "$PORT" --silent)
    [ -n "$FORK_BLOCK" ] && ANVIL_ARGS+=(--fork-block-number "$FORK_BLOCK")

    nohup "${ANVIL_ARGS[@]}" > "$ANVIL_LOG" 2>&1 &
    ANVIL_PID=$!
    echo "$ANVIL_PID" > "$DATA_DIR/anvil.pid"

    # Wait for Anvil
    for i in $(seq 1 30); do
        if cast block-number --rpc-url "http://localhost:$PORT" > /dev/null 2>&1; then
            FORK_AT=$(cast block-number --rpc-url "http://localhost:$PORT")
            ok "Anvil ready at block $FORK_AT (PID: $ANVIL_PID)"
            break
        fi
        sleep 1
        [ $i -eq 30 ] && { fail "Anvil didn't start in 30s"; cat "$ANVIL_LOG"; exit 1; }
    done

    # Switch to auto-mining for deploy
    cast rpc anvil_setAutomine true --rpc-url "http://localhost:$PORT" > /dev/null 2>&1 || true

    # 1b. Run deploy command
    if [ -n "$DEPLOY_CMD" ]; then
        step "1b" "Running deploy command..."
        info "$DEPLOY_CMD"
        eval "$DEPLOY_CMD"
        EXIT_CODE=$?
        if [ $EXIT_CODE -ne 0 ]; then
            fail "Deploy command failed (exit=$EXIT_CODE)"
            kill "$ANVIL_PID" 2>/dev/null || true
            exit 1
        fi
        ok "Deploy complete"
    else
        step "1b" "No --deploy command (fork-only mode)"
    fi

    # 1c. Warm up contracts (ensure lazy-loaded state is in dump)
    step "1c" "Warming contract cache..."
    bash "$LIB_DIR/warmup.sh" "http://localhost:$PORT" "$DATA_DIR"
    ok "Contracts warmed"

    # 1d. Dump Anvil state
    step "1d" "Dumping Anvil state..."
    DUMP_FILE="$DATA_DIR/anvil-dump.json"
    cast rpc anvil_dumpState --rpc-url "http://localhost:$PORT" 2>/dev/null > "$DATA_DIR/dump-raw.txt"

    python3 -c "
import json, gzip
raw = open('$DATA_DIR/dump-raw.txt').read().strip()
if raw.startswith('\"') and raw.endswith('\"'): raw = raw[1:-1]
if raw.startswith('0x'): raw = raw[2:]
raw_bytes = bytes.fromhex(raw)
if raw_bytes[:2] == b'\x1f\x8b':
    data = json.loads(gzip.decompress(raw_bytes))
else:
    data = json.loads(raw_bytes)
json.dump(data, open('$DUMP_FILE', 'w'))
accounts = data.get('accounts', data)
print(f'  {len(accounts)} accounts dumped')
"
    rm -f "$DATA_DIR/dump-raw.txt"
    ok "State dumped"

    # 1e. Convert to Reth genesis
    step "1e" "Converting to Reth genesis..."
    FUND_KEY_ARGS=""
    for key in "${FUND_KEYS[@]+${FUND_KEYS[@]}}"; do
        FUND_KEY_ARGS="$FUND_KEY_ARGS --fund-keys $key"
    done

    python3 "$LIB_DIR/convert_state.py" \
        --input "$DUMP_FILE" \
        --output "$GENESIS_FILE" \
        --chain-id "$CHAIN_ID" \
        $FUND_KEY_ARGS

    rm -f "$DUMP_FILE"
    GENESIS_SIZE=$(du -h "$GENESIS_FILE" | cut -f1)
    ok "Genesis ready ($GENESIS_SIZE)"

    # 1f. Kill Anvil
    step "1f" "Stopping Anvil..."
    kill "$ANVIL_PID" 2>/dev/null || true
    wait "$ANVIL_PID" 2>/dev/null || true
    rm -f "$DATA_DIR/anvil.pid"
    ok "Anvil stopped"
fi

# ═════════════════════════════════════════════════════════════
# PHASE 2: BOOT RETH
# ═════════════════════════════════════════════════════════════
header "PHASE 2: BOOT RETH"

# Kill any existing Reth on this port
if [ -f "$PIDFILE" ]; then
    OLD_PID=$(cat "$PIDFILE")
    kill "$OLD_PID" 2>/dev/null || true
    wait "$OLD_PID" 2>/dev/null || true
fi

mkdir -p "$RETH_DATADIR"

ACCOUNT_COUNT=$(python3 -c "import json; print(len(json.load(open('$GENESIS_FILE'))['alloc']))" 2>/dev/null || echo "?")

step "2a" "Starting Reth..."
info "Port: $PORT | Block time: ${BLOCK_TIME}s | Accounts: $ACCOUNT_COUNT"

RETH_CMD=(
    reth node
    --dev
    --dev.block-time "${BLOCK_TIME}s"
    --chain "$GENESIS_FILE"
    --datadir "$RETH_DATADIR"
    --http
    --http.addr "0.0.0.0"
    --http.port "$PORT"
    --http.api "eth,net,web3,debug,trace,txpool"
    --http.corsdomain "*"
    --log.stdout.filter "error"
)

nohup "${RETH_CMD[@]}" > "$RETH_LOG" 2>&1 &
RETH_PID=$!
echo "$RETH_PID" > "$PIDFILE"

# Wait for Reth
for i in $(seq 1 60); do
    if cast block-number --rpc-url "http://localhost:$PORT" > /dev/null 2>&1; then
        BLOCK=$(cast block-number --rpc-url "http://localhost:$PORT")
        ok "Reth ready at block $BLOCK (PID: $RETH_PID)"
        break
    fi
    [ $((i % 10)) -eq 0 ] && info "Still starting... (${i}/60s)"
    sleep 1
    [ $i -eq 60 ] && { fail "Reth didn't start in 60s"; tail -20 "$RETH_LOG"; exit 1; }
done

# ═════════════════════════════════════════════════════════════
# STATUS
# ═════════════════════════════════════════════════════════════
echo ""
echo -e "${GREEN}═══════════════════════════════════════════════════${NC}"
echo -e "${GREEN}✅ forge-persist running!${NC}"
echo -e "${GREEN}${NC}"
echo -e "${GREEN}   RPC:        http://localhost:${PORT}${NC}"
echo -e "${GREEN}   Block time: ${BLOCK_TIME}s${NC}"
echo -e "${GREEN}   Data:       ${DATA_DIR}/${NC}"
echo -e "${GREEN}   PID:        ${RETH_PID}${NC}"
echo -e "${GREEN}${NC}"
echo -e "${GREEN}   Resume:   forge-persist --resume${NC}"
echo -e "${GREEN}   Stop:     forge-persist --stop${NC}"
echo -e "${GREEN}   Fresh:    forge-persist --fork-url \$RPC --fresh${NC}"
echo -e "${GREEN}   Logs:     tail -f ${RETH_LOG}${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════${NC}"

if [ "$BACKGROUND" = false ]; then
    echo ""
    info "Running in foreground. Ctrl+C to stop."
    trap "kill $RETH_PID 2>/dev/null; rm -f $PIDFILE; echo '  Stopped.'; exit 0" INT TERM
    tail -f "$RETH_LOG"
fi
