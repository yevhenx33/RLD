FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    clickhouse-connect==0.15.1 \
    pandas==3.0.2 \
    numpy==2.4.4 \
    requests==2.33.1

COPY data-pipeline/scripts/fluid_realtime_indexer.py /app/fluid_realtime_indexer.py

ENV PYTHONUNBUFFERED=1

CMD ["python", "/app/fluid_realtime_indexer.py"]
