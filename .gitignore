# ═══════════════════════════════════════════════════════════════
# RLD Protocol — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Environment & Secrets ──────────────────────────────────────
.env
.env.*
!.env.example
rate-dashboard.env

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/

# ── JavaScript / Node ──────────────────────────────────────────
node_modules/
dist/

# ── Forge / Foundry ────────────────────────────────────────────
contracts/broadcast/
contracts/cache/
contracts/out/
*.sol.bak

# ── Databases ──────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Logs & Build Artifacts ─────────────────────────────────────
*.log
*_logs.txt
deploy_output.txt
build_error.log

# ── Simulation State (generated by deployer — never commit) ───
docker/deployment.json

# ── Backups & State ────────────────────────────────────────────
backups/
logs/

# ── Internal Docs (not for public) ─────────────────────────────
docs/internal/
docs/internal_audit/

# ── OS Files ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
^out/

# Stale local DB files (live data is in Docker volumes)
backend/data/
data/
*.env
!*.env.enc
secrets.txt
.venv/
scratch/
cds-research/
